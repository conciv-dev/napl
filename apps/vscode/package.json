{
  "name": "napl",
  "displayName": "NAPL",
  "description": "Syntax highlighting and language server for napl (.napl) prompt files.",
  "version": "0.1.0",
  "publisher": "napl",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:napl",
    "workspaceContains:**/.napl"
  ],
  "contributes": {
    "languages": [
      {
        "id": "napl",
        "aliases": [
          "NAPL",
          "napl"
        ],
        "extensions": [
          ".napl",
          ".🧑",
          ".🧓",
          ".👤",
          ".👨",
          ".👩",
          ".🧒"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "napl",
        "scopeName": "source.napl",
        "path": "./syntaxes/napl.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.yaml": "yaml"
        }
      }
    ],
    "configuration": {
      "title": "NAPL",
      "properties": {
        "napl.cliPath": {
          "type": "string",
          "default": "napl",
          "description": "Path to the napl CLI binary that hosts the language server (run as `napl lsp`). A command on PATH (default \"napl\") or an absolute path to the binary."
        }
      }
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "package": "npx @vscode/vsce package --no-dependencies --allow-missing-repository"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.75.0",
    "esbuild": "^0.24.0",
    "typescript": "^7.0.2"
  }
}
