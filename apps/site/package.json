{
  "name": "site",
  "version": "0.0.0",
  "private": true,
  "homepage": "https://napl.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conciv-dev/napl.git",
    "directory": "apps/site"
  },
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite dev --port 3002",
    "build": "vite build",
    "start": "vite preview",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "typecheck": "fumadocs-mdx && tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "build:fixtures": "node scripts/build-fixtures.mjs"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.3.0",
    "@fontsource-variable/jetbrains-mono": "^5.3.0",
    "@napl/editor": "workspace:*",
    "@napl/grammar": "workspace:*",
    "@napl/wasm": "workspace:*",
    "@tanstack/react-router": "1.170.15",
    "@tanstack/react-start": "1.168.25",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.26.0",
    "radix-ui": "^1.6.0",
    "react-resizable-panels": "^4.12.2",
    "fumadocs-core": "^16.10.2",
    "fumadocs-mdx": "^15.0.12",
    "fumadocs-ui": "^16.10.2",
    "mermaid": "^11.15.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.4",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/mdx": "^2.0.14",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^25.0.1",
    "playwright": "^1.61.1",
    "shiki": "^4.2.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
