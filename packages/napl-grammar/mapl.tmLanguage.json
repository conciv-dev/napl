{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MAPL",
  "scopeName": "source.mapl",
  "fileTypes": ["mapl", "🤖"],
  "patterns": [
    {
      "include": "#entry-kind"
    },
    {
      "include": "#yaml"
    }
  ],
  "repository": {
    "entry-kind": {
      "patterns": [
        {
          "match": "^(\\s*kind\\s*:\\s*)(ambiguity)(?=\\s*(?:#.*)?$)",
          "captures": {
            "1": {
              "name": "meta.mapping.key.mapl"
            },
            "2": {
              "name": "invalid.illegal.ambiguity.mapl"
            }
          }
        },
        {
          "match": "^(\\s*kind\\s*:\\s*)(assumption|no-op)(?=\\s*(?:#.*)?$)",
          "captures": {
            "1": {
              "name": "meta.mapping.key.mapl"
            },
            "2": {
              "name": "markup.changed.warning.machine-margin.mapl"
            }
          }
        },
        {
          "match": "^(\\s*kind\\s*:\\s*)(note)(?=\\s*(?:#.*)?$)",
          "captures": {
            "1": {
              "name": "meta.mapping.key.mapl"
            },
            "2": {
              "name": "markup.inline.raw.info.machine-margin.mapl"
            }
          }
        }
      ]
    },
    "yaml": {
      "patterns": [
        {
          "match": "^\\s*(?:-\\s+)?([A-Za-z][A-Za-z0-9_-]*)(\\s*:)",
          "captures": {
            "1": {
              "name": "entity.name.tag.yaml"
            },
            "2": {
              "name": "punctuation.separator.key-value.yaml"
            }
          }
        },
        {
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.yaml"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.yaml"
            }
          },
          "name": "string.quoted.double.yaml",
          "patterns": [
            {
              "match": "\\\\.",
              "name": "constant.character.escape.yaml"
            }
          ]
        },
        {
          "begin": "'",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.yaml"
            }
          },
          "end": "'",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.yaml"
            }
          },
          "name": "string.quoted.single.yaml"
        },
        {
          "match": "\\b(?:true|false|null)\\b",
          "name": "constant.language.yaml"
        },
        {
          "match": "\\b\\d+\\b",
          "name": "constant.numeric.yaml"
        },
        {
          "match": "#.*$",
          "name": "comment.line.number-sign.yaml"
        },
        {
          "match": "^-\\s+",
          "name": "punctuation.definition.entry.yaml"
        }
      ]
    }
  }
}
