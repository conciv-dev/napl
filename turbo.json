{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": ["pnpm-workspace.yaml", "tsconfig.base.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build", "build"]
    },
    "conformance": {
      "dependsOn": ["^build"],
      "cache": false
    }
  }
}
