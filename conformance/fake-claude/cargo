#!/usr/bin/env node
const argv = process.argv.slice(2);

if (argv[0] === 'test') {
  const output = process.env.NAPL_FAKE_TEST_OUTPUT;
  if (typeof output === 'string' && output !== '') {
    process.stdout.write(output.endsWith('\n') ? output : `${output}\n`);
  }
  const exit = Number.parseInt(process.env.NAPL_FAKE_TEST_EXIT ?? '0', 10);
  process.exit(Number.isNaN(exit) ? 0 : exit);
}

process.exit(0);
